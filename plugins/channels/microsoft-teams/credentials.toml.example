# Place at the host_path declared by the "dir" fine_grained_permission in
# manifest.toml, named exactly `teams_credentials.toml`. Never commit the
# real file -- it contains an Azure AD client secret.
#
# See teams-app-manifest/SETUP.md for how to obtain these values.

tenant_id = "00000000-0000-0000-0000-000000000000"
client_id = "11111111-1111-1111-1111-111111111111"
client_secret = "<azure-ad-app-client-secret>"

# AAD application id of the registered bot. Must match the `botId` in
# teams-app-manifest/manifest.json. Used to recognize real @-mention chips
# (chatMessage.mentions[].mentioned.application.id) and to detect the bot's
# own outbound messages for the self-loop guard.
bot_app_id = "22222222-2222-2222-2222-222222222222"

# Display name used for the plain-text "@Name" mention fallback when a
# message wasn't sent with a real mention chip.
bot_display_name = "ZeroClaw"

[[teams]]
team_id = "33333333-3333-3333-3333-333333333333"
channel_id = "19:abcdef0123456789@thread.tacv2"
alias = "engineering"

[[teams]]
team_id = "44444444-4444-4444-4444-444444444444"
channel_id = "19:ghijkl0123456789@thread.tacv2"
alias = "support"
